  "item": [
    {
      "name": "0 · Setup & Health",
      "description": "Unauthenticated probes for the gateway and engine. Use these to confirm both services are up and the gateway is publishing its JWKS (which the engine fetches to trust act-as-user tokens).",
      "item": [
        {
          "name": "Gateway · JWKS (public signing key)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{authBaseUrl}}/.well-known/jwks.json", "host": ["{{authBaseUrl}}"], "path": [".well-known", "jwks.json"] },
            "description": "The gateway's public key. luke-core-engine fetches this (LUKE_AUTH_GATEWAY_JWKS_URL) to verify the act-as-user tokens the gateway signs."
          }
        },
        {
          "name": "Gateway · Health",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{authBaseUrl}}/actuator/health", "host": ["{{authBaseUrl}}"], "path": ["actuator", "health"] }
          }
        },
        {
          "name": "Engine · Health (direct)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{engineBaseUrl}}/actuator/health", "host": ["{{engineBaseUrl}}"], "path": ["actuator", "health"] }
          }
        }
      ]
    },
    {
      "name": "1 · Identity (via Gateway)",
      "item": [
        {
          "name": "Who am I",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.code === 200);",
                  "const me = pm.response.json();",
                  "console.log('userId:', me.userId, '| operator:', me.operator);",
                  "console.log('tenants:', JSON.stringify(me.tenants), '| groups:', JSON.stringify(me.groups));",
                  "if (me.tenants && me.tenants.length && !pm.collectionVariables.get('tenantId')) {",
                  "  pm.collectionVariables.set('tenantId', me.tenants[0]);",
                  "  console.log('Captured tenantId =', me.tenants[0]);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{authBaseUrl}}/api/me", "host": ["{{authBaseUrl}}"], "path": ["api", "me"] },
            "description": "Resolves the authenticated user's identity context (groups, tenants, operator flag). The consumer UI uses this for role-based nav gating. Proves your Clerk token → engine identity mapping works end-to-end."
          }
        }
      ]
    },
    {
      "name": "2 · Process Definitions (via Gateway)",
      "item": [
        {
          "name": "List (latest versions)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.code === 200);",
                  "const defs = pm.response.json();",
                  "if (Array.isArray(defs) && defs.length) {",
                  "  pm.collectionVariables.set('processDefinitionId', defs[0].id);",
                  "  pm.collectionVariables.set('processDefinitionKey', defs[0].key);",
                  "  console.log('Captured processDefinitionId =', defs[0].id, '| key =', defs[0].key);",
                  "} else { console.log('No process definitions — deploy a BPMN first.'); }"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Tenant-Id", "value": "{{tenantId}}" }],
            "url": {
              "raw": "{{authBaseUrl}}/engine-rest/process-definition?latestVersion=true&sortBy=name&sortOrder=asc",
              "host": ["{{authBaseUrl}}"],
              "path": ["engine-rest", "process-definition"],
              "query": [
                { "key": "latestVersion", "value": "true" },
                { "key": "sortBy", "value": "name" },
                { "key": "sortOrder", "value": "asc" }
              ]
            }
          }
        },
        {
          "name": "Count",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Tenant-Id", "value": "{{tenantId}}" }],
            "url": { "raw": "{{authBaseUrl}}/engine-rest/process-definition/count", "host": ["{{authBaseUrl}}"], "path": ["engine-rest", "process-definition", "count"] }
          }
        },
        {
          "name": "Get by key",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Tenant-Id", "value": "{{tenantId}}" }],
            "url": { "raw": "{{authBaseUrl}}/engine-rest/process-definition/key/{{processDefinitionKey}}", "host": ["{{authBaseUrl}}"], "path": ["engine-rest", "process-definition", "key", "{{processDefinitionKey}}"] }
          }
        },
        {
          "name": "Get BPMN XML",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Tenant-Id", "value": "{{tenantId}}" }],
            "url": { "raw": "{{authBaseUrl}}/engine-rest/process-definition/{{processDefinitionId}}/xml", "host": ["{{authBaseUrl}}"], "path": ["engine-rest", "process-definition", "{{processDefinitionId}}", "xml"] }
          }
        },
        {
          "name": "Start instance (by key)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200/201', () => [200,201].includes(pm.response.code));",
                  "if ([200,201].includes(pm.response.code)) {",
                  "  const inst = pm.response.json();",
                  "  pm.collectionVariables.set('processInstanceId', inst.id);",
                  "  console.log('Started processInstanceId =', inst.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"businessKey\": \"postman-{{$timestamp}}\",\n  \"variables\": {\n    \"sampleVar\": { \"value\": \"hello from postman\", \"type\": \"String\" }\n  }\n}"
            },
            "url": { "raw": "{{authBaseUrl}}/engine-rest/process-definition/key/{{processDefinitionKey}}/start", "host": ["{{authBaseUrl}}"], "path": ["engine-rest", "process-definition", "key", "{{processDefinitionKey}}", "start"] },
            "description": "Requires CREATE_INSTANCE permission on the definition (e.g. tenant-user / task-worker roles)."
          }
        }
      ]
    },
